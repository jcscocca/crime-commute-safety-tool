MCA_DATABASE_URL=postgresql+psycopg://mca:mca@localhost:5432/mca
MCA_USER_HASH_SALT=replace-with-local-random-salt
MCA_ENVIRONMENT=local
MCA_SESSION_SECRET=replace-with-local-random-session-secret
MCA_SESSION_COOKIE_SECURE=false
MCA_MINIMUM_STOP_DURATION_MINUTES=10
MCA_STOP_RADIUS_M=75
MCA_CLUSTER_RADIUS_M=100
MCA_MINIMUM_CLUSTER_VISITS=3
MCA_MINIMUM_CLUSTER_TOTAL_DWELL_MINUTES=60
MCA_CRIME_RADII_M='[250,500,1000]'
MCA_SOCRATA_BASE_URL=https://data.seattle.gov/resource
MCA_SOCRATA_DATASET_ID=tazs-3rd5
SOCRATA_APP_TOKEN=

# Assistant LLM — an OpenAI-compatible /chat/completions endpoint (llama.cpp/llama-swap, vLLM, ...).
# If unreachable, only the Analyst chat panel is affected; the rest of the app works.
MCA_LLM_BASE_URL=http://127.0.0.1:8080/v1
MCA_LLM_MODEL=gemma-4-26b-a4b-it-ud-q4-k-m-ctx32k

# Bearer token for hosted OpenAI-compatible endpoints (e.g. Groq). Leave empty for
# local llama-swap. Fallback endpoint inherits MCA_LLM_API_KEY unless overridden.
MCA_LLM_API_KEY=
MCA_LLM_FALLBACK_API_KEY=

# Public-demo rate limiting (all enforcement off unless enabled; see docs/DEMO.md).
MCA_RATE_LIMIT_ENABLED=false
MCA_TRUST_PROXY_HEADERS=false
MCA_RATE_LIMIT_SESSIONS_PER_HOUR=10
MCA_RATE_LIMIT_ASSISTANT_PER_HOUR=20
MCA_RATE_LIMIT_ASSISTANT_GLOBAL_PER_DAY=100
MCA_RATE_LIMIT_BURST_PER_MINUTE=120

# Geocoding (address search proxy)
MCA_GEOCODER_PROVIDER=nominatim
MCA_GEOCODER_BASE_URL=https://nominatim.openstreetmap.org/search
MCA_GEOCODER_USER_AGENT=CompCat/0.1
MCA_GEOCODER_CONTACT_EMAIL=
MCA_GEOCODER_CACHE_TTL_DAYS=30
MCA_GEOCODER_MAX_RESULTS=5
MCA_GEOCODER_TIMEOUT_S=5.0
MCA_GEOCODER_MIN_INTERVAL_S=1.0

# Personal location-history uploads. OFF by default — the /uploads endpoints 404, the
# personal_timeline input mode is hidden, and no upload UI renders until this is true.
MCA_PUBLIC_ENABLE_PERSONAL_UPLOADS=false
# When false (default), raw points and per-visit stops are discarded after clustering;
# only the derived place clusters are kept. Set true to retain raw points for re-clustering.
MCA_RAW_UPLOAD_RETENTION=false
